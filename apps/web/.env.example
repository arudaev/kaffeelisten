# Supabase — get from your project settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Resend — get from resend.com/api-keys
# Server-side only — never prefix with VITE_
RESEND_API_KEY=re_your_key

# Admin configuration
# Server-side only — never prefix with VITE_
ADMIN_EMAIL=admin@itc1.de
ADMIN_PIN=1234

# Vercel Cron secret — used to authenticate cron job requests
# Server-side only — never prefix with VITE_
CRON_SECRET=your-cron-secret

# Supabase — get from your project settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Resend — get from resend.com/api-keys
# Server-side only — never prefix with VITE_
RESEND_API_KEY=re_your_key

# Admin configuration
# Server-side only — never prefix with VITE_
# ADMIN_EMAIL is the bootstrap report recipient. Once app_settings.report_recipients
# is populated from the dashboard (Phase 2), that list takes precedence.
ADMIN_EMAIL=admin@itc1.de
# ADMIN_PIN is the bootstrap PIN, used only until an admin sets a PIN in the
# dashboard (then app_settings.admin_pin_hash takes precedence). Phase 2: 6 digits.
ADMIN_PIN=123456
# Last-resort PIN reset backstop. Entering this 6-digit value at the reset screen
# always clears the stored PIN, even if email reset is unavailable. Keep secret.
ADMIN_RECOVERY_PIN=000000
# Secret used to sign the admin session cookie (HMAC-SHA256). Required — admin
# endpoints fail closed (500) if it is unset. Use a long random value, e.g.
# `openssl rand -hex 32`, and set it in Vercel before deploying.
ADMIN_SESSION_SECRET=change-me-to-a-long-random-hex-string

# Vercel Cron secret — used to authenticate cron job requests
# Server-side only — never prefix with VITE_
CRON_SECRET=your-cron-secret
